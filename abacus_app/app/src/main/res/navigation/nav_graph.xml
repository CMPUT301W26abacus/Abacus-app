<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_saved">

    <!-- Bottom nav: Saved (entrant) -->
    <fragment
        android:id="@+id/nav_saved"
        android:name="com.example.abacus_app.MainSavedFragment"
        android:label="Saved" />

    <!-- Bottom nav: History (entrant) -->
    <fragment
        android:id="@+id/nav_history"
        android:name="com.example.abacus_app.MainHistoryFragment"
        android:label="History" />

    <!-- Bottom nav: Inbox (entrant) / Notifications (organizer) -->
    <fragment
        android:id="@+id/nav_inbox"
        android:name="com.example.abacus_app.MainInboxFragment"
        android:label="Inbox" />

    <!-- Opened from list item tap -->
    <fragment
        android:id="@+id/eventDetailsFragment"
        android:name="com.example.abacus_app.EventDetailsFragment"
        android:label="Event Details" />

    <!-- Opened from profile button top right -->
    <fragment
        android:id="@+id/mainProfileFragment"
        android:name="com.example.abacus_app.ProfileFragment"
        android:label="Profile" />

    <!-- Opened from QR scan button -->
    <fragment
        android:id="@+id/mainQrScanFragment"
        android:name="com.example.abacus_app.MainQrScanFragment"
        android:label="Scan QR" />

    <!-- Opened from QR button in EventDetails -->
    <fragment
        android:id="@+id/eventQrFragment"
        android:name="com.example.abacus_app.EventQrFragment"
        android:label="Event QR" />

    <!-- Organizer: Create Event -->
    <fragment
        android:id="@+id/organizerCreateFragment"
        android:name="com.example.abacus_app.OrganizerCreateFragment"
        android:label="Create Event" />

    <!-- Organizer: Manage Event -->
    <fragment
        android:id="@+id/organizerManageFragment"
        android:name="com.example.abacus_app.OrganizerManageFragment"
        android:label="Manage Event" />

    <!-- Organizer/Admin: Tools landing page -->
    <fragment
        android:id="@+id/organizerToolsFragment"
        android:name="com.example.abacus_app.OrganizerToolsFragment"
        android:label="Tools" />

    <!-- Organizer/Admin: Logs -->
    <fragment
        android:id="@+id/organizerLogsFragment"
        android:name="com.example.abacus_app.OrganizerLogsFragment"
        android:label="Logs" />

</navigation>