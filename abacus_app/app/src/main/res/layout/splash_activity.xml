<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1714">

    <!-- Logo -->
    <ImageView
        android:id="@+id/splashAbacus"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/ic_abacus_animated"
        android:contentDescription="Abacus logo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- App Name -->
    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Abacus"
        android:textColor="#F5F0E8"
        android:textSize="38sp"
        android:fontFamily="serif"
        android:letterSpacing="-0.02"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/splashAbacus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Byline -->
    <TextView
        android:id="@+id/tvByline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="by Abacus"
        android:textColor="#6B6259"
        android:textSize="11sp"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="0.12"
        android:textAllCaps="true"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- CTA Button -->
    <Button
        android:id="@+id/btnGetStarted"
        android:layout_width="180dp"
        android:layout_height="48dp"
        android:text="Get Started"
        android:textColor="#F5F0E8"
        android:textSize="12sp"
        android:letterSpacing="0.08"
        android:textAllCaps="true"
        android:fontFamily="sans-serif-medium"
        android:backgroundTint="#C96A3A"
        android:layout_marginTop="52dp"
        app:layout_constraintTop_toBottomOf="@id/tvByline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Browse as Guest → MainActivity (no auth) -->
    <TextView
        android:id="@+id/tvBrowseGuest"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Browse events as guest"
        android:textColor="#C96A3A"
        android:textSize="13sp"
        android:paddingVertical="12dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnGetStarted"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom badge -->
    <TextView
        android:id="@+id/tvFooter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Accessibility for everyone"
        android:textColor="#3D3830"
        android:textSize="10sp"
        android:letterSpacing="0.16"
        android:textAllCaps="true"
        android:layout_marginBottom="36dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
