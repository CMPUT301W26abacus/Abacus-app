<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_grey">

    <!-- Scrollable body -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:overScrollMode="never"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="100dp"
            android:paddingHorizontal="16dp"
            android:paddingBottom="40dp">

            <!-- Avatar + name card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAvatar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imgAvatar"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/ic_avatar_placeholder"
                        android:contentDescription="User Avatar"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_avatar_placeholder" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDisplayedName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Your Name"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="@color/black"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvDisplayedEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text=""
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/grey" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipRole"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Entrant"
                            android:textSize="11sp"
                            android:clickable="false"
                            android:focusable="false"
                            app:chipMinHeight="24dp"
                            android:visibility="gone" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/btnUploadPhoto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Change photo"
                        android:textSize="12sp"
                        style="?attr/borderlessButtonStyle"
                        android:textColor="#6B7280"
                        android:visibility="gone" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Admin view-mode toggle — only visible to admin accounts -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAdminViewMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:letterSpacing="0.1"
                        android:text="VIEW MODE"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="@color/grey" />

                    <RadioGroup
                        android:id="@+id/rgViewMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rbViewEntrant"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Entrant" />

                        <RadioButton
                            android:id="@+id/rbViewOrganizer"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Organizer" />

                        <RadioButton
                            android:id="@+id/rbViewAdmin"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:checked="true"
                            android:gravity="center"
                            android:text="Admin" />

                    </RadioGroup>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Guest banner -->
            <androidx.cardview.widget.CardView
                android:id="@+id/tvGuestBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="#FFF8F0"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="2dp"
                    android:padding="16dp"
                    android:text="You're browsing as a guest. Link an account to save your profile across devices."
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/black" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/labelSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.1"
                android:text="PERSONAL INFO"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="@color/grey" />

            <!-- Fields card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardFields"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/labelName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Display name"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/input_background"
                        android:hint="Your name"
                        android:inputType="textPersonName|textCapWords"
                        android:paddingHorizontal="14dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/black"
                        android:textColorHint="@color/grey" />

                    <TextView
                        android:id="@+id/tvNameError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="#EF4444"
                        android:visibility="gone" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="@color/grey" />

                    <TextView
                        android:id="@+id/labelEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Email address"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/input_background"
                        android:hint="you@example.com"
                        android:inputType="textEmailAddress"
                        android:paddingHorizontal="14dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/black"
                        android:textColorHint="@color/grey" />

                    <TextView
                        android:id="@+id/tvEmailError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="#EF4444"
                        android:visibility="gone" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="@color/grey" />

                    <TextView
                        android:id="@+id/labelPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Phone number"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/etPhone"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/input_background"
                        android:hint="+1 (555) 000-0000"
                        android:inputType="phone"
                        android:paddingHorizontal="14dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/black"
                        android:textColorHint="@color/grey" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Bio card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardBio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Bio"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/etBio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/input_background"
                        android:hint="Tell people about yourself"
                        android:inputType="textMultiLine|textCapSentences"
                        android:minLines="3"
                        android:maxLines="5"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/black"
                        android:textColorHint="@color/grey"
                        android:gravity="top" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Organization name card (organizers only) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardOrgName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Organization name"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/etOrgName"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/input_background"
                        android:hint="Your organization or event brand"
                        android:inputType="textCapWords"
                        android:paddingHorizontal="14dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/black"
                        android:textColorHint="@color/grey" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Role-specific stats card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvStatCount1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/black" />

                        <TextView
                            android:id="@+id/tvStatLabel1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Events"
                            android:textSize="12sp"
                            android:textColor="@color/grey" />

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/grey"
                        android:layout_marginHorizontal="8dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvStatCount2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/black" />

                        <TextView
                            android:id="@+id/tvStatLabel2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Registrations"
                            android:textSize="12sp"
                            android:textColor="@color/grey" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnLinkAccount"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/black"
                android:text="Link Account"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/white"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/black"
                android:text="Save changes"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/white"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnPreferences"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#F3F4F6"
                android:text="Event Preferences"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/black"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnAccessibility"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#F3F4F6"
                android:text="Accessibility"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/black"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#F3F4F6"
                android:text="Log out"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/black"
                android:visibility="gone" />

            <View
                android:id="@+id/dangerDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:background="@color/grey"
                android:visibility="gone" />

            <TextView
                android:id="@+id/labelDanger"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.1"
                android:text="DANGER ZONE"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="#EF4444"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnDeleteProfile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:backgroundTint="#FEF2F2"
                android:text="Delete profile"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="#EF4444"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Back button overlaid top-left, matching event_qr_fragment pattern -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="50dp"
        android:background="@android:color/transparent"
        android:contentDescription="Go back"
        android:src="@drawable/ic_arrow_back"
        app:tint="@color/black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Title centered horizontally at same vertical position -->
    <TextView
        android:id="@+id/tvTopBarTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:gravity="center"
        android:text="Profile"
        android:textAppearance="?attr/textAppearanceHeadlineSmall"
        android:textColor="@color/black"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>