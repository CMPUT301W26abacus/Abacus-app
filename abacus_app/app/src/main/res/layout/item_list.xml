<?xml version="1.0" encoding="utf-8"?>
<!--
    item_event.xml
    RecyclerView item layout for a single event.
    Used in: EventsFragment (and any other screen reusing the event list).
-->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/light_grey"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Event Poster / Thumbnail -->
        <!-- Place your event poster image here. Use Glide/Picasso to load dynamically. -->
        <!-- Default placeholder icon: ic_event_poster (your asset) -->
        <ImageView
            android:id="@+id/iv_event_poster"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_rounded_image"
            android:clipToOutline="true"
            android:contentDescription="Event poster"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_event_poster"
            android:tint="#96F8F8F8"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <!-- Note: Create bg_rounded_image as a shape drawable with cornerRadius="8dp" -->

        <!-- Event Title -->
        <TextView
            android:id="@+id/tv_event_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="List item"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            app:layout_constraintEnd_toStartOf="@id/btn_join_status"
            app:layout_constraintStart_toEndOf="@id/iv_event_poster"
            app:layout_constraintTop_toTopOf="@id/iv_event_poster" />

        <!-- Date & Time -->
        <!-- Icon: ic_calendar (your asset) placed as drawableStart -->
        <TextView
            android:id="@+id/tv_event_datetime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:drawablePadding="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Category • 1.2 miles away"
            android:textAppearance="?attr/textAppearanceBodySmall"
            app:layout_constraintEnd_toStartOf="@id/btn_join_status"
            app:layout_constraintStart_toEndOf="@id/iv_event_poster"
            app:layout_constraintTop_toBottomOf="@id/tv_event_title" />
        <!--
            Set drawableStartCompat in code or XML to:
            ic_calendar  — for date/time
        -->

        <!-- Location -->
        <!-- Icon: ic_location_pin (your asset) placed as drawableStart -->
        <TextView
            android:id="@+id/tv_event_location"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:drawablePadding="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Supporting line text lorem ipsum..."
            android:textAppearance="?attr/textAppearanceBodySmall"
            app:layout_constraintBottom_toBottomOf="@id/iv_event_poster"
            app:layout_constraintEnd_toStartOf="@id/btn_join_status"
            app:layout_constraintStart_toEndOf="@id/iv_event_poster"
            app:layout_constraintTop_toBottomOf="@id/tv_event_datetime" />
        <!--
            Set drawableStartCompat in code or XML to:
            ic_location_pin  — for location
        -->

        <!-- Join Status Button -->
        <!--
            States (set programmatically in adapter):
              - "Join"         → enabled, primary style
              - "Joined"       → disabled or secondary style
              - "Closed"       → disabled, muted style
              - "Unavailable"  → disabled, muted style
            Icon tip: you can place ic_heart or ic_waitlist as drawableStart on this button.
            Currently mirrors the heart icon from the Figma mockup; swap to a pill-style
            status chip by switching to com.google.android.material.chip.Chip if preferred.
        -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_join_status"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:paddingHorizontal="10dp"
            android:text="Join"
            android:textColor="@color/light_grey"
            android:textSize="12sp"
            app:backgroundTint="@color/orange"
            app:iconTint="@color/grey"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageButton
            android:id="@+id/imageButton2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#00FFFFFF"
            app:tint="@color/black"
            app:layout_constraintBottom_toTopOf="@+id/btn_join_status"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tv_event_title"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_favourite" />

        <!--
            To show a heart/save icon instead of a text button, replace MaterialButton with:
            <ImageButton
                android:id="@+id/btn_join_status"
                android:src="@drawable/ic_heart"   ← your asset
                ... />
        -->

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>