<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude SharedPreferences with PII or auth tokens from cloud backup (API 31+) -->
        <exclude domain="sharedpref" path="user_prefs.xml"/>
        <exclude domain="sharedpref" path="guest_prefs.xml"/>
        <exclude domain="sharedpref" path="abacus_prefs.xml"/>
        <exclude domain="sharedpref" path="accessibility_prefs.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- Also exclude from local device-to-device transfers -->
        <exclude domain="sharedpref" path="user_prefs.xml"/>
        <exclude domain="sharedpref" path="guest_prefs.xml"/>
        <exclude domain="sharedpref" path="abacus_prefs.xml"/>
    </device-transfer>
</data-extraction-rules>