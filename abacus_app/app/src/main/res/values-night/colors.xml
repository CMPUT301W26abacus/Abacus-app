<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ── Base palette (night) ───────────────────────────────────── -->
    <color name="black">#C6C6CA</color>
    <color name="white">#000000</color>
    <color name="grey">#636365</color>
    <color name="light_grey">#161617</color>

    <!-- ── Your existing colors (DARK-ADJUSTED where needed) ──────── -->
    <color name="surface_tint">#1C1C1E</color>

    <!-- Keep same brand colors unless you WANT dark variants -->
    <color name="orange">#C96A3A</color>
    <color name="error_red">#CF6679</color> <!-- optional: better for dark -->

    <!-- From Farhan -->
    <color name="card_stroke">#333333</color>

    <!-- Guest banner: warm dark tone instead of the very light orange (#FFF8F0) that
         the light-mode value would render on a dark background. -->
    <color name="color_guest_banner_bg">#2A1F15</color>

    <!-- Waitlist status colours: lightened variants for dark-mode contrast.
         Without these the light-mode values (e.g. deep blue #3B82F6) are too dark
         against the dark surface and fail WCAG AA contrast requirements. -->
    <color name="color_status_waitlisted_orange">#D4844E</color>
    <color name="color_status_invited_blue">#60A5FA</color>
    <color name="color_status_accepted_green">#34D399</color>
    <color name="color_status_declined_red">#F87171</color>
    <color name="color_status_canceled_black">#9CA3AF</color>

    <!-- UI utility colors (dark-mode adjusted) -->
    <color name="color_hint">#2C2C2E</color>
    <color name="color_danger">#F87171</color>
    <color name="color_profile_bg">#1C1C1E</color>
    <color name="login_button_text">#FFFFFF</color>

</resources>